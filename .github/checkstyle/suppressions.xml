<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Suppress JavadocPackage for all source files -->
    <suppress checks="JavadocPackage" files=".*"/>
    
    <!-- Spring Boot Application classes should be lenient -->
    <!-- These are entry points, not utility classes, and don't need final parameters -->
    <suppress checks="FinalParameters" files=".*Application\.java"/>
    <suppress checks="HideUtilityClassConstructor" files=".*Application\.java"/>
    
    <!-- Configuration classes often need mutable parameters -->
    <suppress checks="FinalParameters" files=".*Config\.java"/>
    <suppress checks="FinalParameters" files=".*Configuration\.java"/>
</suppressions>
