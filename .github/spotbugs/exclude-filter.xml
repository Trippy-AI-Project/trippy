<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs exclude filter for the Trippy platform.

    EI_EXPOSE_REP / EI_EXPOSE_REP2 - JPA entities are mutable by design.
    Defensive copies of @Entity objects would break Hibernate's identity tracking,
    so these warnings are intentional false positives for all entity classes.
-->
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                            https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!--
        JPA entity classes are mutable by framework design.
        Suppressing EI_EXPOSE_REP and EI_EXPOSE_REP2 for all classes
        annotated with @Entity or @MappedSuperclass.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <Class name="~.*\.model\.entity\..*"/>
        </Or>
    </Match>

</FindBugsFilter>
