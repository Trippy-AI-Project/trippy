{
  "rabbit_version": "3.13.0",
  "rabbitmq_version": "3.13.0",
  "users": [
    {
      "name": "trippy_mq",
      "password_hash": "",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["administrator"],
      "limits": {}
    }
  ],
  "vhosts": [
    {
      "name": "trippy"
    }
  ],
  "permissions": [
    {
      "user": "trippy_mq",
      "vhost": "trippy",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "topic_permissions": [],
  "parameters": [],
  "global_parameters": [
    {
      "name": "cluster_name",
      "value": "trippy-rabbitmq-cluster"
    }
  ],
  "policies": [
    {
      "vhost": "trippy",
      "name": "ha-all",
      "pattern": ".*",
      "apply-to": "all",
      "definition": {
        "ha-mode": "all",
        "ha-sync-mode": "automatic"
      },
      "priority": 0
    }
  ],
  "queues": [
    {
      "name": "notification.email",
      "vhost": "trippy",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 86400000,
        "x-dead-letter-exchange": "trippy.dlx",
        "x-dead-letter-routing-key": "notification.email.dead"
      }
    },
    {
      "name": "notification.push",
      "vhost": "trippy",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 86400000,
        "x-dead-letter-exchange": "trippy.dlx",
        "x-dead-letter-routing-key": "notification.push.dead"
      }
    },
    {
      "name": "chat.messages",
      "vhost": "trippy",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 604800000
      }
    }
  ],
  "exchanges": [
    {
      "name": "trippy.events",
      "vhost": "trippy",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "trippy.dlx",
      "vhost": "trippy",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "trippy.notifications",
      "vhost": "trippy",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "trippy.notifications",
      "vhost": "trippy",
      "destination": "notification.email",
      "destination_type": "queue",
      "routing_key": "email",
      "arguments": {}
    },
    {
      "source": "trippy.notifications",
      "vhost": "trippy",
      "destination": "notification.push",
      "destination_type": "queue",
      "routing_key": "push",
      "arguments": {}
    }
  ]
}
