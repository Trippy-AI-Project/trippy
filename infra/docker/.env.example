# =============================================================================
# Trippy Platform - Infrastructure Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=trippy
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trippy_db
POSTGRES_USER=trippy_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_123!
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB

# Connection string for services
DATABASE_URL=postgresql://trippy_admin:CHANGE_ME_STRONG_PASSWORD_123!@postgres:5432/trippy_db

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_456!
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Connection string for services
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_456!@redis:6379

# -----------------------------------------------------------------------------
# RABBITMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=trippy_mq
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBITMQ_PASSWORD_789!
RABBITMQ_DEFAULT_VHOST=trippy

# Connection string for services
RABBITMQ_URL=amqp://trippy_mq:CHANGE_ME_RABBITMQ_PASSWORD_789!@rabbitmq:5672/trippy

# -----------------------------------------------------------------------------
# SONARQUBE
# -----------------------------------------------------------------------------
SONARQUBE_PORT=9000
SONARQUBE_JDBC_URL=jdbc:postgresql://postgres:5432/sonarqube_db
SONARQUBE_JDBC_USERNAME=sonar_user
SONARQUBE_JDBC_PASSWORD=CHANGE_ME_SONAR_DB_PASSWORD!
SONAR_ES_BOOTSTRAP_CHECKS_DISABLE=true

# SonarQube Admin (change after first login)
SONARQUBE_ADMIN_USER=admin
SONARQUBE_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# NETWORKING
# -----------------------------------------------------------------------------
NETWORK_SUBNET=172.28.0.0/16

# Service IPs (optional, for static assignment)
POSTGRES_IP=172.28.1.1
REDIS_IP=172.28.1.2
RABBITMQ_IP=172.28.1.3
SONARQUBE_IP=172.28.1.4

# -----------------------------------------------------------------------------
# VOLUMES - Host paths for persistent data
# -----------------------------------------------------------------------------
DATA_PATH=./data

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_MAX_SIZE=50m
LOG_MAX_FILE=5

# -----------------------------------------------------------------------------
# RESOURCE LIMITS (Production tuning)
# -----------------------------------------------------------------------------
# PostgreSQL
POSTGRES_CPU_LIMIT=2
POSTGRES_MEMORY_LIMIT=2g
POSTGRES_MEMORY_RESERVATION=1g

# Redis
REDIS_CPU_LIMIT=1
REDIS_MEMORY_LIMIT=1g
REDIS_MEMORY_RESERVATION=512m

# RabbitMQ
RABBITMQ_CPU_LIMIT=1
RABBITMQ_MEMORY_LIMIT=1g
RABBITMQ_MEMORY_RESERVATION=512m

# SonarQube
SONARQUBE_CPU_LIMIT=2
SONARQUBE_MEMORY_LIMIT=4g
SONARQUBE_MEMORY_RESERVATION=2g

# -----------------------------------------------------------------------------
# HEALTHCHECK INTERVALS
# -----------------------------------------------------------------------------
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=60s

# -----------------------------------------------------------------------------
# BACKUP CONFIGURATION
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=./backups
